{
  "name": "llm-premier-league",
  "version": "0.1.0",
  "description": "Agent-driven LLM debate benchmark: double round-robin league, peer judging",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "verified": "tsx src/verified/run.ts",
    "verified:sim": "LLM_SIM=1 SANDBOX=local tsx src/verified/run.ts --id verified-sim --rounds 1 --cheap",
    "enroll": "tsx src/enroll.ts",
    "verify": "./verify.sh"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
