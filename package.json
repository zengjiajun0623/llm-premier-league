{
  "name": "llm-premier-league",
  "version": "0.1.0",
  "description": "Agent-driven LLM debate benchmark: double round-robin league, peer judging",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "verified": "tsx src/verified/run.ts",
    "verified:sim": "LLM_SIM=1 SANDBOX=local tsx src/verified/run.ts --id verified-sim --rounds 1 --cheap",
    "propose": "tsx src/verified/admission/propose.ts",
    "propose:sim": "LLM_SIM=1 SANDBOX=local tsx src/verified/admission/propose.ts --sim --proposer lab/admit",
    "enroll": "tsx src/enroll.ts",
    "forecast": "tsx src/forecast/run.ts",
    "forecast:sim": "FORECAST_SIM=1 FEED_SIM=1 tsx src/forecast/run.ts",
    "agentic": "tsx src/agentic/run.ts",
    "agentic:sim": "AGENTIC_SIM=1 FEED_SIM=1 tsx src/agentic/run.ts pose --id agentic-sim",
    "verify": "./verify.sh",
    "audit": "tsx src/verified/audit.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
